<view class="container">
  <view class="header">
    <text class="title">My Categories 馃挜</text>
  </view>

  <view class="cat-list">
    <view class="cat-item kawaii-card" wx:for="{{categories}}" wx:key="*this">
      <text class="cat-name">{{item}}</text>
      <view class="delete-btn" bindtap="deleteCat" data-index="{{index}}">鉂?</view>
    </view>
  </view>

  <view class="add-cat-box kawaii-card">
    <input class="kawaii-input" placeholder="New category..." bindinput="onInput" value="{{newCat}}" />
    <view class="kawaii-btn add-btn" bindtap="addCat">Add</view>
  </view>
</view>