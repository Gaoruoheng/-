.container {
  background: #F7F5F3;
  min-height: 100vh;
  position: relative;
}

.page-scroll {
  height: calc(100vh - 150rpx);
  box-sizing: border-box;
  padding-bottom: 60rpx;
}

.top-nav {
  display: flex;
  align-items: center;
  padding: 80rpx 220rpx 24rpx 24rpx;
  background: #FFF;
  border-bottom: 2rpx solid #F0F0F0;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}
.back-btn {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #5C4B51;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}
.back-arrow { font-size: 40rpx; font-weight: 900; color: #5C4B51; }
.nav-title { flex: 1; font-size: 36rpx; font-weight: 900; color: #5C4B51; }
.save-top-btn {
  background: #FFB7C5;
  color: #FFF;
  font-size: 28rpx;
  font-weight: bold;
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  border: 4rpx solid #5C4B51;
  box-shadow: 3rpx 3rpx 0rpx #5C4B51;
}

.section {
  margin: 0 24rpx 30rpx;
  padding: 30rpx;
  background: #FFF;
  border: 4rpx solid #5C4B51;
  border-radius: 30rpx;
  box-shadow: 4rpx 4rpx 0rpx #5C4B51;
}
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx dashed #F0F0F0;
}
.section-title-wrap {
  flex: 1;
  min-width: 0;
}
.section-title { font-size: 32rpx; font-weight: 900; color: #5C4B51; display: block; }
.section-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #AAA;
  line-height: 1.4;
}
.add-cat-btn {
  width: 56rpx;
  height: 56rpx;
  font-size: 32rpx;
  padding: 0;
  background: #FFB7C5;
  color: #FFF;
  border: 4rpx solid #5C4B51;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 3rpx 3rpx 0rpx #5C4B51;
}

.field-item { margin-bottom: 24rpx; }
.field-item:last-child { margin-bottom: 0; }
.field-label { display: block; font-size: 26rpx; font-weight: bold; color: #888; margin-bottom: 10rpx; }
.field-input {
  width: 100%;
  height: 80rpx;
  border: 4rpx solid #5C4B51;
  border-radius: 20rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  background: #FFFDF9;
}

.add-cat-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: #FFF0F3;
  border-radius: 16rpx;
}
.cat-input {
  flex: 1;
  height: 72rpx;
  border: 4rpx solid #5C4B51;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #FFF;
  margin-right: 16rpx;
}
.confirm-btn {
  width: 90rpx;
  height: 72rpx;
  font-size: 28rpx;
  padding: 0;
  background: #FFB7C5;
  color: #FFF;
  border: 4rpx solid #5C4B51;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 3rpx 3rpx 0rpx #5C4B51;
}

/* 拖拽列表 */
.drag-list { position: relative; }

.cat-item {
  display: flex;
  align-items: center;
  padding: 22rpx 14rpx;
  border-bottom: 2rpx solid #F7F7F7;
  background: #FFF;
  transition: background 0.15s, opacity 0.15s, box-shadow 0.15s;
  box-sizing: border-box;
  width: 100%;
}
.cat-item.cat-placeholder {
  opacity: 0.28;
  background: #FFF0F3;
}
.cat-item.cat-over {
  background: #FFF0F3;
  box-shadow: inset 0 8rpx 0 #FFB7C5;
}

.drag-handle {
  width: 42rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.handle-icon {
  font-size: 32rpx;
  color: #CCC;
}

.cat-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FFF0F3;
  border: 3rpx solid #FFB7C5;
  color: #FF8FAB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  flex-shrink: 0;
  margin-right: 12rpx;
  box-sizing: border-box;
}

.cat-name { flex: 1; font-size: 30rpx; color: #5C4B51; font-weight: bold; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cat-count {
  font-size: 24rpx;
  color: #FFB7C5;
  flex-shrink: 0;
  margin-left: 12rpx;
  margin-right: 12rpx;
  max-width: 120rpx;
  text-align: right;
  white-space: nowrap;
}
.cat-arrow { font-size: 32rpx; color: #CCC; flex-shrink: 0; }

/* 浮动拖拽层 */
.drag-floating {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  z-index: 999;
  pointer-events: none;
}
.cat-floating {
  display: flex;
  align-items: center;
  padding: 22rpx 14rpx;
  background: #FFF;
  border: 4rpx solid #FFB7C5;
  border-radius: 20rpx;
  box-shadow: 0 14rpx 34rpx rgba(255,183,197,0.55);
  opacity: 0.98;
  border-bottom: 4rpx solid #FFB7C5;
  box-sizing: border-box;
  transform: scale(1.02);
}

/* Stats */
.stats-grid { display: flex; gap: 20rpx; }
.stat-box {
  flex: 1;
  background: #FFF0F3;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  border: 3rpx solid #FFB7C5;
}
.stat-num { display: block; font-size: 48rpx; font-weight: 900; color: #FFB7C5; }
.stat-label { display: block; font-size: 22rpx; color: #AAA; margin-top: 6rpx; }

.empty-tip { text-align: center; padding: 40rpx; font-size: 26rpx; color: #CCC; }

.share-section {
  background: #FFFDF9;
}
.share-code-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid #5C4B51;
  border-radius: 24rpx;
  background: #FFF0F3;
  text-align: center;
  box-shadow: 3rpx 3rpx 0 #5C4B51;
}
.share-code-label {
  display: block;
  color: #888;
  font-size: 22rpx;
  font-weight: 900;
}
.share-code-text {
  display: block;
  margin-top: 8rpx;
  color: #5C4B51;
  font-size: 46rpx;
  font-weight: 900;
  letter-spacing: 5rpx;
}
.share-code-status {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #E2F0CB;
  color: #5f8873;
  font-size: 22rpx;
  font-weight: 900;
}
.share-actions {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}
.share-action {
  min-height: 68rpx;
  margin: 8rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #5C4B51;
  border-radius: 20rpx;
  background: #FFF;
  color: #5C4B51;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 3rpx 3rpx 0 #5C4B51;
}
.share-action.primary {
  background: #FFB7C5;
  color: #FFF;
}
.share-action.danger {
  background: #FFF5F5;
  color: #E76F7A;
}
.shared-user-list {
  margin-top: 24rpx;
}
.shared-user-title {
  display: block;
  margin-bottom: 14rpx;
  color: #5C4B51;
  font-size: 26rpx;
  font-weight: 900;
}
.shared-user {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-top: 2rpx dashed #F0F0F0;
}
.shared-avatar {
  width: 58rpx;
  height: 58rpx;
  margin-right: 14rpx;
  border: 3rpx solid #5C4B51;
  border-radius: 50%;
  background: #FFF0F3;
}
.shared-avatar-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FF8FAB;
  font-size: 20rpx;
  font-weight: 900;
}
.shared-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #5C4B51;
  font-size: 26rpx;
  font-weight: 900;
}
.shared-remove {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border: 2rpx solid #FFAAAA;
  border-radius: 999rpx;
  color: #E76F7A;
  font-size: 22rpx;
  font-weight: 900;
}

.danger-section { border-color: #FFCCCC; box-shadow: 4rpx 4rpx 0rpx #FFAAAA; }
.danger-btn {
  background: #FFF5F5;
  border: 3rpx solid #FFAAAA;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  color: #FF4444;
  font-weight: bold;
}
