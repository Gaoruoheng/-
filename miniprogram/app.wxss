/**app.wxss**/
page {
  --theme-color: #5C4B51; /* Dark Brown */
  --bg-color: #F8F3E9; /* Off-white/Cream */
  --accent-color: #F0A07C; /* Soft Coral/Orange */
  --border-radius: 20rpx;
  --box-shadow: 4rpx 4rpx 0px rgba(92, 75, 81, 1);
  --border-thick: 4rpx solid #5C4B51;
  background-color: var(--bg-color);
  color: var(--theme-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  box-sizing: border-box;
}

view, text, scroll-view, image {
  box-sizing: border-box;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 30rpx;
}

/* Button Reset & Global Cute Style */
button {
  background: #FFF;
  color: var(--theme-color);
  border: var(--border-thick);
  border-radius: var(--border-radius);
  box-shadow: var(--box-shadow);
  font-weight: bold;
  font-size: 32rpx;
  padding: 20rpx 40rpx;
  line-height: 1.5;
  transition: all 0.1s ease;
}

button::after {
  display: none;
}

button:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0px rgba(92, 75, 81, 1);
}

.btn-primary {
  background: var(--accent-color);
  color: #FFF;
}
